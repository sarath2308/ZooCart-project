                                <div class="hero__social">
                                    <a href="#"><i class="fa fa-facebook"></i></a>
                                    <a href="#"><i class="fa fa-twitter"></i></a>
                                    <a href="#"><i class="fa fa-pinterest"></i></a>
                                    <a href="#"><i class="fa fa-instagram"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="hero__items set-bg" data-setbg="img/image1.jpg" style="background-size: cover; background-position: center center;">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-5 col-lg-7 col-md-8">
                            <div class="hero__text">
                                <h6>iPhone Collection</h6>
                                <h2>iPhone 14 Series - 2030</h2>
                                <p>Discover the new iPhone with cutting-edge features and design.</p>
                                <a href="#" class="primary-btn btn-info">Shop now <span class="arrow_right"></span></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <% if(bannerData.banner2) { %>
            <div class="hero__items set-bg" data-setbg="<%=bannerData.banner2.image%>" style="background-size: cover; background-position: center center;">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-5 col-lg-7 col-md-8">
                            <div class="hero__text">
                                <h6>Summer Collection</h6>
                                <h2>Fall - Winter Collections 2030</h2>
                                <p>Experience the luxury of our new collections with exceptional quality and design.</p>
                                <a href="<%= bannerData.banner2.product ? '/productDetails?id=' + bannerData.banner2.product : '#' %>" class="primary-btn btn-info">Shop now <span class="arrow_right"></span></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="hero__items set-bg" data-setbg="https://res.cloudinary.com/dlel7tyzq/image/upload/v1743941181/hero2_dr2hmp.jpg" style="background-size: cover; background-position: center center;">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-5 col-lg-7 col-md-8">
                            <div class="hero__text">
                                <h6>Summer Collection</h6>
                                <h2>Fall - Winter Collections 2030</h2>
                                <a href="#" class="primary-btn btn-info">Shop now <span class="arrow_right"></span></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</section>
<style>
    
    .product-img-action-wrap { position: relative; }
    .product-action-1 {
        position: absolute; top: 0px; right: 80px; background: rgba(0, 0, 0, 0.5);
        padding: 5px; border-radius: 50%; transition: background 0.3s ease;
    }
    .product-action-1:hover { background: rgba(0, 0, 0, 0.8); }
    .product-action-1 i { color: white; font-size: 18px; }
    .swal2-toast { font-size: 12px !important; font-family: 'Arial', sans-serif; }
</style>

<section class="banner spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-7 offset-lg-4">
                <div class="banner__item">
                    <div class="banner__item__pic">
                        <img src="<%= bannerData.banner3 ? bannerData.banner3.image : 'img/image3.jpg' %>" alt="">
                    </div>
                    <div class="banner__item__text">
                        <h2>Android Collections 2030</h2>
                        <a style="color:#091db1;" href="<%= (bannerData.banner3 && bannerData.banner3.product) ? '/productDetails?id='+bannerData.banner3.product : '#' %>">Shop now</a>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-5">
                <div class="banner__item banner__item--middle">
                    <div class="banner__item__pic">
                        <img src="<%= bannerData.banner4 ? bannerData.banner4.image : 'img/image4.jpg' %>" alt="">
                    </div>
                    <div class="banner__item__text">
                        <h2>Flagships</h2>
                        <a style="color:#091db1;" href="<%= (bannerData.banner4 && bannerData.banner4.product) ? '/productDetails?id='+bannerData.banner4.product : '#' %>">Shop now</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="banner__item banner__item--last">
                    <div class="banner__item__pic">
                        <img src="<%= bannerData.banner5 ? bannerData.banner5.image : 'img/image5.jpg' %>" alt="">
                    </div>
                    <div class="banner__item__text">
                        <h2>iOS Devices 2030</h2>
                        <a style="color:#091db1;" href="<%= (bannerData.banner5 && bannerData.banner5.product) ? '/productDetails?id='+bannerData.banner5.product : '#' %>">Shop now</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="product spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <ul class="filter__controls">
                    <li class="filter-item">New Arrivals</li>
                </ul>
            </div>
        </div>

      <div class="row product__filter">
    <% for(let i=0; i<products.length; i++) { %>
        <div class="col-lg-3 col-md-6 col-sm-6 mix new-arrivals">
            <div class="product__item">
                <div class="product__item__pic set-bg" data-setbg="<%=products[i].productImage[0]%>" onclick="window.location.href='/productDetails?id=<%=products[i]._id%>'" style="cursor: pointer;">
                    <span class="label" style="background-color: #091db1;color:white;">New</span>
                    <ul class="product__hover">
                        <li>
                            <a onclick="event.preventDefault(); event.stopPropagation(); addToWishlist('<%=products[i]._id%>')">
                                <img src="img/icon/heart.png" alt="wishlist">
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="product__item__text">
                    <h6><%=products[i].productName%></h6>
                    
                    <a onclick="addToCart('<%=products[i]._id%>')" class="add-cart">+ Add To Cart</a>

                    <div class="rating">
                        <i class="fa fa-star-o"></i><i class="fa fa-star-o"></i><i class="fa fa-star-o"></i><i class="fa fa-star-o"></i><i class="fa fa-star-o"></i>
                    </div>
                    <h5><s style="font-size: 13px;color:grey;">₹<%=products[i].regularPrice%></s> ₹<%=products[i].salePrice%>.0</h5>
                </div>
            </div>
        </div>
    <% } %>
</div>
    </div>
</section>

<script>
    function addToCart(pid) {
        $.ajax({
            url: `/addToCart`,
            method: 'POST',
            data: JSON.stringify({ pid: pid }),
            contentType: "application/json",
            dataType: "json",
            success: function (response) {
                Swal.fire({
                    title: response.message, icon: 'success', toast: true,
                    position: 'top-end', showConfirmButton: false, timer: 2000
                });
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.href = '/signup';
                    return;
                }
                let errorMessage = xhr.responseJSON ? xhr.responseJSON.message : "Something went wrong!";
                Swal.fire({
                    title: errorMessage, icon: 'error', toast: true,
                    position: 'top-end', showConfirmButton: false, timer: 2000
                });
            }
        });
    }

    function addToWishlist(pid) {
        $.ajax({
            url: `/addToWishlist`,
            method: 'POST',
            data: { pid: pid },
            success: function (response) {
                if(response.success) {
                    Swal.fire({
                        title: response.message, icon: 'success', toast: true,
                        position: 'top-end', showConfirmButton: false, timer: 2000
                    });
                }
            },
            error: function (xhr) {
                if (xhr.status === 401) {
                    window.location.href = '/signup';
                    return;
                }
                Swal.fire({
                    title: "Action failed", icon: 'error', toast: true,
                    position: 'top-end', showConfirmButton: false, timer: 2000
                });
            }
        });
    }
</script>

<%-include("../../views/partials/user/footer.ejs")%>