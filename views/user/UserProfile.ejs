<%- include("../../views/partials/user/header.ejs") %>

<style>
/* Premium Profile Dashboard Styling */
.profile-dashboard {
    padding: 60px 0 100px;
    background-color: #fcfcfc;
    min-height: 70vh;
}

.dashboard-header {
    text-align: center;
    margin-bottom: 50px;
}

.dashboard-header h2 {
    font-weight: 700;
    color: #111;
    margin-bottom: 10px;
    font-size: 32px;
}

.dashboard-header p {
    color: #777;
    font-size: 16px;
}

.profile-card {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #eee;
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    text-decoration: none !important;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    min-height: 180px;
    height: 100%;
}

.profile-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(9, 29, 177, 0.1);
    border-color: #091db1;
}

.profile-card .icon-wrapper {
    width: 70px;
    height: 70px;
    background-color: #f4f6ff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: all 0.3s ease;
}

.profile-card:hover .icon-wrapper {
    background-color: #091db1;
}

.profile-card .icon-wrapper i {
    font-size: 28px;
    color: #091db1;
    transition: all 0.3s ease;
}

.profile-card:hover .icon-wrapper i {
    color: #ffffff;
}

.profile-card .card-title {
    font-size: 18px;
    font-weight: 600;
    color: #333;
    margin: 0;
    transition: color 0.3s ease;
}

.profile-card:hover .card-title {
    color: #091db1;
}

/* Specific styling for the logout card */
.profile-card.logout-card:hover {
    box-shadow: 0 15px 30px rgba(220, 53, 69, 0.15);
    border-color: #dc3545;
}

.profile-card.logout-card .icon-wrapper {
    background-color: #fff0f1;
}

.profile-card.logout-card:hover .icon-wrapper {
    background-color: #dc3545;
}

.profile-card.logout-card .icon-wrapper i {
    color: #dc3545;
}

.profile-card.logout-card:hover .icon-wrapper i {
    color: #ffffff;
}

.profile-card.logout-card .card-title {
    color: #dc3545;
}

.profile-card.logout-card:hover .card-title {
    color: #dc3545;
}

/* Grid Gap Adjustment */
.g-4 {
    --bs-gutter-y: 1.5rem;
    --bs-gutter-x: 1.5rem;
}
</style>

<div class="profile-dashboard">
    <div class="container">
        <div class="dashboard-header">
            <h2>My Account</h2>
            <p>Manage your personal information, orders, and account preferences</p>
        </div>

        <div class="row g-4 justify-content-center" style="max-width: 1100px; margin: 0 auto;">
            
            <!-- User Details -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/userDetails" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-user"></i>
                    </div>
                    <h3 class="card-title">User Details</h3>
                </a>
            </div>

            <!-- Edit Personal Details -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/editUserProfile" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-user-edit"></i>
                    </div>
                    <h3 class="card-title">Edit Personal Details</h3>
                </a>
            </div>

            <!-- Change Email -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/change-email" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <h3 class="card-title">Change Email</h3>
                </a>
            </div>

            <!-- Change Password -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/change-password" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-key"></i>
                    </div>
                    <h3 class="card-title">Change Password</h3>
                </a>
            </div>

            <!-- Cart -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/cart" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h3 class="card-title">My Cart</h3>
                </a>
            </div>

            <!-- Orders -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/orders" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-shopping-bag"></i>
                    </div>
                    <h3 class="card-title">My Orders</h3>
                </a>
            </div>

            <!-- Wallet -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/wallet" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <h3 class="card-title">My Wallet</h3>
                </a>
            </div>

            <!-- Address Management -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/address" class="profile-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h3 class="card-title">Address Management</h3>
                </a>
            </div>

            <!-- Logout -->
            <div class="col-12 col-sm-6 col-lg-4 mb-4">
                <a href="/logout" class="profile-card logout-card">
                    <div class="icon-wrapper">
                        <i class="fas fa-sign-out-alt"></i>
                    </div>
                    <h3 class="card-title">Log Out</h3>
                </a>
            </div>

        </div>
    </div>
</div>

<%- include("../../views/partials/user/footer.ejs") %>
