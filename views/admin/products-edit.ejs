<%- include("../../views/partials/admin/header") %>

<style>
    .error-message { color: red; }
    .image-cropper-container { width: 100%; max-height: 400px; margin-bottom: 20px; display: none; background-color: #f8f9fa; border: 1px dashed #ccc; }
    .image-cropper-container img { display: block; max-width: 100%; }
    .img-preview { max-width: 100%; height: 200px; object-fit: contain; margin-top: 10px; border: 1px solid #ddd; display: none; }
    .card-body-img { padding: 1.5rem; border: 1px solid #eee; margin-bottom: 1rem; border-radius: 8px; position: relative; }
</style>

<section class="content-main">
    <div class="content-header mb-4">
        <a href="/admin/products" class="btn btn-warning">Back</a>
        <h2 class="content-title mt-2">Edit Product: <%= data.productName %></h2>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" id="productAdd" action="/admin/products/editproduct?id=<%=data._id%>" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-lg-7">
                        <div class="mb-4">
                            <label class="form-label">Product Name</label>
                            <input type="text" name="productName" class="form-control" value="<%=data.productName%>" id="product_name">
                        </div>

                        <div class="row">
                            <div class="col-lg-6 mb-4">
                                <label class="form-label">Brand</label>
                                <select class="form-select" name="brand">
                                    <% brands.forEach((br) => { %>
                                        <option value="<%= br.brandName %>" <%= data.brand === br.brandName ? 'selected' : '' %>><%= br.brandName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-lg-6 mb-4">
                                <label class="form-label">Category</label>
                                <select class="form-select" name="category">
                                    <% cat.forEach((category) => { %>
                                        <option value="<%= category.name %>" <%= data.category.name === category.name ? 'selected' : '' %>><%= category.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Full Description</label>
                            <textarea name="description" class="form-control" rows="4"><%= data.discription %></textarea>
                        </div>

                        <div class="row">
                            <div class="col-lg-4 mb-4">
                                <label class="form-label">Regular Price</label>
                                <input name="regularPrice" type="text" value="<%=data.regularPrice%>" class="form-control">
                            </div>
                            <div class="col-lg-4 mb-4">
                                <label class="form-label">Sale Price</label>
                                <input name="salePrice" type="text" value="<%=data.salePrice%>" class="form-control">
                            </div>
                            <div class="col-lg-4 mb-4">
                                <label class="form-label">Quantity</label>
                                <input name="quantity" type="number" id="stock" onchange="stockCheck(this.value)" value="<%=data.quantity%>" class="form-control">
                                <% if(data.quantity <= 10) { %><small class="text-danger">Low stock!</small><% } %>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Color</label>
                            <input name="color" type="text" value="<%=data.color%>" class="form-control">
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card mb-4">
                            <div class="card-header"><h4>Product Images</h4></div>
                            <div class="card-body">
                                <% for (let i = 0; i < 4; i++) { %>
                                    <div class="card-body-img">
                                        <label class="form-label">Image <%= i + 1 %></label>
                                        
                                        <% if (data.productImage[i]) { %>
                                            <div id="existingPreview<%= i %>">
                                                <img src="<%= data.productImage[i] %>" style="width: 100px; height: 100px; object-fit: cover;" class="mb-2">
                                                <button type="button" class="btn btn-sm btn-danger d-block mb-2" onclick="deleteImage('<%=data.productImage[i]%>', '<%=data._id %>')">Delete</button>
                                            </div>
                                        <% } %>

                                        <input class="form-control" type="file" name="images" id="input<%= i %>" accept="image/*" onchange="initCropper(event, <%= i %>)">
                                        
                                        <div class="image-cropper-container" id="cropperContainer<%= i %>">
                                            <img id="imgView<%= i %>">
                                        </div>
                                        
                                        <img id="croppedImg<%= i %>" class="img-preview">
                                        
                                        <button type="button" id="saveButton<%= i %>" class="btn btn-sm btn-primary mt-2" style="display:none" onclick="saveCrop(<%= i %>)">Save Crop</button>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        <button class="btn btn-success btn-lg w-100" type="button" onclick='validateAndSubmit(<%= JSON.stringify(data.productImage) %>)'>Update Product</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    const cropperStore = {};

    function initCropper(event, index) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const img = document.getElementById('imgView' + index);
            const container = document.getElementById('cropperContainer' + index);
            const btn = document.getElementById('saveButton' + index);
            const preview = document.getElementById('croppedImg' + index);
            const existing = document.getElementById('existingPreview' + index);

            if (cropperStore[index]) cropperStore[index].destroy();
            if (existing) existing.style.display = 'none';

            preview.style.display = 'none';
            container.style.display = 'block';
            btn.style.display = 'inline-block';

            img.onload = function() {
                setTimeout(() => {
                    cropperStore[index] = new Cropper(img, {
                        aspectRatio: 1,
                        viewMode: 1,
                        autoCropArea: 1
                    });
                }, 50);
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    function saveCrop(index) {
        const cropper = cropperStore[index];
        if (!cropper) return;

        const canvas = cropper.getCroppedCanvas({ width: 600, height: 600 });
        const preview = document.getElementById('croppedImg' + index);
        preview.src = canvas.toDataURL('image/jpeg');
        preview.style.display = 'block';

        document.getElementById('cropperContainer' + index).style.display = 'none';
        document.getElementById('saveButton' + index).style.display = 'none';

        canvas.toBlob(blob => {
            const file = new File([blob], `edit_crop_${Date.now()}.jpg`, { type: 'image/jpeg' });
            const dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('input' + index).files = dt.files;
        }, 'image/jpeg');

        cropper.destroy();
        delete cropperStore[index];
    }

    function deleteImage(imageId, productId) {
        Swal.fire({
            title: "Delete image?",
            text: "This cannot be undone!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, delete it!"
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: "/admin/products/deleteImage",
                    method: "post",
                    data: { imageId, productId },
                    success: (response) => {
                        if (response.success) {
                            location.reload();
                        } else {
                            Swal.fire("Error", response.message, "error");
                        }
                    }
                });
            }
        });
    }

    function validateAndSubmit(existingImages) {
        let hasImage = existingImages.length > 0;
        
        // Check if new images were added
        for (let i = 0; i < 4; i++) {
            if (document.getElementById('input' + i).files.length > 0) {
                hasImage = true;
                break;
            }
        }

        if (!hasImage) {
            Swal.fire('Error', 'Product must have at least one image', 'error');
            return;
        }

        document.getElementById('productAdd').submit();
    }

    function stockCheck(stock) {
        if (stock > 1000) {
            Swal.fire("Caution", "Stock level is unusually high.", "warning");
        }
    }
</script>

<%- include("../../views/partials/admin/footer") %>