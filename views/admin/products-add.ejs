<%- include("../../views/partials/admin/header") %>



    <style>
        .error-message { color: #dc3545; font-size: 0.875rem; margin-top: 0.25rem; }
        .image-cropper-container {
            width: 100%;
            max-height: 400px;
            margin-bottom: 20px;
            display: none;
            background-color: #f8f9fa;
            border: 1px dashed #ccc;
        }
        .image-cropper-container img { display: block; max-width: 100%; }
        .img-preview {
            max-width: 100%;
            height: 200px;
            object-fit: contain;
            margin-top: 10px;
            border: 1px solid #ddd;
            display: none;
        }
        .card-body-img {
            padding: 1.5rem;
            border: 1px solid #eee;
            margin-bottom: 1rem;
            border-radius: 8px;
        }
    </style>

<% if (typeof message !== 'undefined' && success === false) { %>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
        Swal.fire({
          title: '<%= message %>',
          icon: 'error',
          toast: true,
          position: 'top-end',
          showConfirmButton: false,
          timer: 3000
        });
    });
  </script>
<% } else if (typeof message !== 'undefined' && success === true) { %>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
        Swal.fire({
          title: '<%= message %>',
          icon: 'success',
          toast: true,
          position: 'top-end',
          showConfirmButton: false,
          timer: 3000
        });
    });
  </script>
<% } %>

<section class="content-main">
    <div class="content-header d-flex justify-content-between align-items-center mb-4">
        <h2 class="content-title card-title">Add New Product</h2>
        <div>
            <a href="/admin/products" class="btn btn-warning me-2">Back</a>
            <a href="/admin/logout" class="btn btn-danger">Logout</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" id="productAdd" action="/admin/products/addproducts" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-lg-7">
                        <div class="mb-4">
                            <label class="form-label">Product Name</label>
                            <input type="text" name="productName" class="form-control" id="product_name" placeholder="Type here">
                            <div id="productName-error" class="error-message"></div>
                        </div>

                        <div class="row">
                            <div class="col-lg-6 mb-4">
                                <label class="form-label">Brand</label>
                                <select class="form-select" name="brand">
                                    <% brands.forEach((br) => { %>
                                        <option value="<%= br.brandName %>"><%= br.brandName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-lg-6 mb-4">
                                <label class="form-label">Category</label>
                                <select class="form-select" name="category">
                                    <% cat.forEach((category) => { %>
                                        <option value="<%= category.name %>"><%= category.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Full Description</label>
                            <textarea id="descriptionid" name="description" class="form-control" rows="4" placeholder="Type here"></textarea>
                            <div id="description-error" class="error-message"></div>
                        </div>

                        <div class="row">
                            <div class="col-lg-4 mb-4">
                                <label class="form-label">Regular Price</label>
                                <input name="regularPrice" type="number" class="form-control" id="regularPrice" placeholder="$">
                                <div id="regularPrice-error" class="error-message"></div>
                            </div>
                            <div class="col-lg-4 mb-4">
                                <label class="form-label">Sale Price</label>
                                <input name="salePrice" type="number" class="form-control" placeholder="$">
                            </div>
                            <div class="col-lg-4 mb-4">
                                <label class="form-label">Quantity</label>
                                <input name="quantity" type="number" class="form-control" id="quantity">
                                <div id="quantity-error" class="error-message"></div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Color</label>
                            <input name="color" type="text" class="form-control" id="color">
                            <div id="color-error" class="error-message"></div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card mb-4">
                            <div class="card-header">
                                <h4>Product Images</h4>
                            </div>
                            <div class="card-body">
                                <% for (let i = 1; i <= 4; i++) { %>
                                    <div class="card-body-img">
                                        <label class="form-label">Image <%= i %></label>
                                        <input class="form-control mb-2" type="file" name="images" id="input<%= i %>" accept="image/*" data-index="<%= i %>" onchange="initCropper(event, this.getAttribute('data-index'))">
                                        
                                        <div class="image-cropper-container" id="cropperContainer<%= i %>">
                                            <img id="imgView<%= i %>">
                                        </div>
                                        
                                        <img id="croppedImg<%= i %>" class="img-preview">
                                        
                                        <button type="button" id="saveButton<%= i %>" class="btn btn-sm btn-primary mt-2" style="display:none" data-index="<%= i %>" onclick="saveCrop(this.getAttribute('data-index'))">
                                            Confirm Crop
                                        </button>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        <div class="d-grid">
                            <button class="btn btn-success btn-lg" type="button" onclick="validateAndSubmit()">Publish Product</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    const cropperStore = {};

    function initCropper(event, index) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const img = document.getElementById('imgView' + index);
            const container = document.getElementById('cropperContainer' + index);
            const btn = document.getElementById('saveButton' + index);
            const preview = document.getElementById('croppedImg' + index);

            if (cropperStore[index]) { cropperStore[index].destroy(); }

            preview.style.display = 'none';
            container.style.display = 'block';
            btn.style.display = 'inline-block';

            img.onload = function() {
                setTimeout(() => {
                    cropperStore[index] = new Cropper(img, {
                        aspectRatio: 1,
                        viewMode: 1,
                        autoCropArea: 1
                    });
                }, 50);
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    function saveCrop(index) {
        const cropper = cropperStore[index];
        if (!cropper) return;

        const canvas = cropper.getCroppedCanvas({ width: 600, height: 600 });
        const preview = document.getElementById('croppedImg' + index);
        preview.src = canvas.toDataURL('image/jpeg');
        preview.style.display = 'block';

        document.getElementById('cropperContainer' + index).style.display = 'none';
        document.getElementById('saveButton' + index).style.display = 'none';

        canvas.toBlob(blob => {
            const fileName = `cropped_${Date.now()}_${index}.jpg`;
            const file = new File([blob], fileName, { type: 'image/jpeg' });
            const dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('input' + index).files = dt.files;
        }, 'image/jpeg');

        cropper.destroy();
        delete cropperStore[index];
    }

    function validateAndSubmit() {
        // Clear errors
        document.querySelectorAll('.error-message').forEach(el => el.textContent = '');
        
        const name = document.getElementById('product_name').value.trim();
        const description = document.getElementById('descriptionid').value.trim();
        const price = document.getElementById('regularPrice').value;
        const qty = document.getElementById('quantity').value;
        const color = document.getElementById('color').value.trim();
        
        let isValid = true;

        if (!name) { document.getElementById('productName-error').textContent = 'Name is required'; isValid = false; }
        if (!description) { document.getElementById('description-error').textContent = 'Description is required'; isValid = false; }
        if (!price || price <= 0) { document.getElementById('regularPrice-error').textContent = 'Valid price is required'; isValid = false; }
        if (!qty || qty < 0) { document.getElementById('quantity-error').textContent = 'Valid quantity is required'; isValid = false; }
        if (!color) { document.getElementById('color-error').textContent = 'Color is required'; isValid = false; }

        // Ensure at least one image is selected
        let hasImage = false;
        for (let i = 1; i <= 4; i++) {
            if (document.getElementById('input' + i).files.length > 0) { hasImage = true; break; }
        }
        
        if (!hasImage) {
            Swal.fire('Error', 'Please upload at least one image', 'error');
            isValid = false;
        }

        if (isValid) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to publish this product?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'Yes, publish it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('productAdd').submit();
                }
            });
        }
    }
</script>

<%- include("../../views/partials/admin/footer") %>